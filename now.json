{
  "name": "valerio-portfolio",
  "version": 2,
  "alias": ["valeriosillari.com", "www.valeriosillari.com"],
  "builds": [
    {
      "src": "screenshot.js",
      "use": "@now/node",
      "config": {
        "maxLambdaSize": "40mb"
      }
    },
    { "src": "package.json", "use": "@now/static-build" }
  ],
  "regions": ["bru", "cdg1", "arn1"],
  "build": {
    "env": {
      "GOOGLE_ANALYTICS_KEY": "@valerio_portfolio_google_analytics_key"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/policy",
      "dest": "/policy.html"
    },
    { "src": "/(.*)", "dest": "/screenshot.js" },
    {
      "src": "/.*",
      "status": 404,
      "dest": "error.html"
    }
  ]
}
